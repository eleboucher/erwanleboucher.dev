---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props
const isActive = (path: string) =>
  path === '/' ? currentPath === '/' : currentPath.startsWith(path)
const isHome = currentPath === '/'
---

<header class="header">
  <div class="identity">
    <div>
      {
        isHome ? (
          <h1 class="name">
            Erwan Leboucher<span class="cursor" aria-hidden="true" />
          </h1>
        ) : (
          <p class="name">
            <a href="/" class="name-link">
              Erwan Leboucher
            </a>
            <span class="cursor" aria-hidden="true" />
          </p>
        )
      }
      <p class="subtitle">Senior Software Engineer · Paris · he/him</p>
    </div>
    <div class="status-badge unknown" id="status-badge" role="status" aria-live="polite">
      <span class="status-dot"></span>
      <span id="status-text">Checking Systems</span>
    </div>
  </div>

  <nav class="nav" aria-label="Main navigation">
    <div class="nav-group">
      <a
        href="/"
        class:list={['nav-link', { active: isActive('/') }]}
        aria-current={isActive('/') ? 'page' : undefined}
      >
        Home
      </a>
      <a
        href="/blog"
        class:list={['nav-link', { active: isActive('/blog') }]}
        aria-current={isActive('/blog') ? 'page' : undefined}
      >
        Blog
      </a>
    </div>
    <div class="nav-group">
      <a
        href="mailto:erwanleboucher@gmail.com"
        class="nav-link external"
        aria-label="Send email to erwanleboucher@gmail.com"
      >
        Email
      </a>
      <a
        href="https://github.com/eleboucher"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link external"
        aria-label="GitHub (opens in new tab)"
      >
        GitHub
      </a>
      <a
        href="https://git.erwanleboucher.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link external"
        aria-label="Forgejo (opens in new tab)"
      >
        Forgejo
      </a>
      <a
        href="https://linkedin.com/in/erwan-leboucher"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link external"
        aria-label="LinkedIn (opens in new tab)"
      >
        LinkedIn
      </a>
      <a
        href="https://keyoxide.org/erwan@erwanleboucher.dev"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link external"
        aria-label="Keyoxide (opens in new tab)"
      >
        Keyoxide
      </a>
      <a
        href="https://ko-fi.com/eleboucher"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link external"
        aria-label="Sponsor on Ko-fi (opens in new tab)"
      >
        Sponsor
      </a>
      <a
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link external"
        aria-label="RSS Feed (opens in new tab)"
      >
        RSS
      </a>
    </div>
  </nav>
</header>

<script>
  import { KROMGO_BASE } from '../constants'
  import type { KromgoEndpointResponse } from '../types'

  const badge = document.getElementById('status-badge')
  const text = document.getElementById('status-text')

  const setStatus = (state: 'operational' | 'degraded' | 'unknown', label: string) => {
    if (!badge || !text) return
    badge.classList.remove('operational', 'degraded', 'unknown')
    badge.classList.add(state)
    text.textContent = label
  }

  const fetchBadge = (key: string): Promise<KromgoEndpointResponse> =>
    fetch(`${KROMGO_BASE}/badges/${key}?format=json`).then((res) =>
      res.ok ? res.json() : Promise.reject(new Error(`${res.status}`)),
    )

  Promise.all([fetchBadge('cluster_alert_count'), fetchBadge('global_sla')])
    .then(([alerts, sla]) => {
      if (alerts.result > 0 || sla.color !== 'green') {
        setStatus('degraded', 'Systems Degraded')
      } else {
        setStatus('operational', 'Systems Operational')
      }
    })
    .catch(() => setStatus('unknown', 'Status Unknown'))
</script>

<style>
  @reference '../app.css';

  .header {
    @apply flex flex-col gap-6 mb-16 pb-6 border-b border-anthracite-800;
  }

  .identity {
    @apply flex flex-col md:flex-row justify-between items-start gap-4;
  }

  .name {
    @apply text-4xl font-bold text-cream-100 tracking-tight leading-none m-0;
  }

  .name-link {
    @apply text-cream-100 no-underline hover:text-navy-300 transition-colors;
  }

  .cursor {
    @apply inline-block bg-navy-300 ml-2 align-baseline;
    width: 0.5ch;
    height: 0.75em;
    animation: cursor-blink 1.2s steps(2, jump-none) infinite;
  }

  @keyframes cursor-blink {
    0% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .subtitle {
    @apply text-sm text-cream-400 mt-2 tracking-wide;
  }

  .status-badge {
    @apply flex items-center gap-2 text-xs text-navy-300 uppercase tracking-widest;
  }

  .status-dot {
    @apply w-1.5 h-1.5 rounded-full bg-[#3fb950] animate-pulse;
  }

  .status-badge.operational {
    @apply text-[#3fb950];
  }

  .status-badge.degraded {
    @apply text-orange-400;
  }

  .status-badge.degraded .status-dot {
    @apply bg-orange-400;
  }

  .status-badge.unknown {
    @apply text-cream-500;
  }

  .status-badge.unknown .status-dot {
    @apply bg-cream-500 animate-none;
  }

  .nav {
    @apply flex flex-col md:flex-row md:flex-wrap md:justify-between gap-4 md:gap-6 text-sm;
  }

  .nav-group {
    @apply flex flex-wrap gap-x-5 gap-y-2 md:gap-6;
  }

  .nav-link {
    @apply text-cream-400 hover:text-cream-100 transition-colors duration-200;
  }

  .nav-link.active {
    @apply text-cream-100 border-b border-navy-400;
  }

  .nav-link.external {
    @apply text-cream-500 hover:text-cream-300;
  }
</style>
