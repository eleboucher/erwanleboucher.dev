---
import { getCollection, render } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.posted)
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
const dateStr = post.data.date.toISOString().slice(0, 10)
const words =
  post.body
    ?.replace(/```[\s\S]*?```/g, ' ')
    .split(/\s+/)
    .filter((t) => /\w/.test(t)).length ?? 0
const minutes = Math.max(1, Math.round(words / 220))
const wordsLabel = words === 1 ? '1 word' : `${words} words`
const canonicalURL = new URL(`/blog/${post.id}`, Astro.site)

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Erwan Leboucher',
    url: 'https://erwanleboucher.dev',
  },
  mainEntityOfPage: canonicalURL.href,
  image: new URL('/og-image.png', Astro.site).href,
}
---

<BaseLayout
  title={`${post.data.title} - Erwan Leboucher`}
  description={post.data.description}
  ogType="article"
  publishedTime={post.data.date.toISOString()}
  jsonLd={jsonLd}
>
  <header class="post-header">
    <a href="/blog" class="back-link">&larr; Back</a>
    <div class="post-meta">
      <span class="post-pill post-pill-date">
        <time datetime={dateStr}>{dateStr}</time>
      </span>
      <span class="post-pill">{wordsLabel}</span>
      <span class="post-pill">{minutes} min read</span>
    </div>
    <h1 class="post-title">{post.data.title}</h1>
    <p class="post-desc">{post.data.description}</p>
  </header>

  <main id="main">
    <article class="prose">
      <Content />
    </article>
  </main>

  <button class="scroll-top" aria-label="Scroll to top" id="scroll-top-btn" hidden> &uarr; </button>
</BaseLayout>

<script>
  const btn = document.getElementById('scroll-top-btn')
  if (btn) {
    window.addEventListener(
      'scroll',
      () => {
        btn.hidden = window.scrollY <= 400
      },
      { passive: true },
    )
    btn.addEventListener('click', () => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      window.scrollTo({ top: 0, behavior: reduceMotion ? 'auto' : 'smooth' })
    })
  }
</script>

<style>
  @reference '../../app.css';

  .post-header {
    @apply flex flex-col gap-3 mb-16 pb-6 border-b border-anthracite-800 max-w-3xl;
  }

  .back-link {
    @apply text-sm text-cream-500 hover:text-cream-200 transition-colors;
  }

  .post-meta {
    @apply flex flex-wrap gap-2 mt-2;
  }

  .post-pill {
    @apply px-2.5 py-1 border border-anthracite-800 rounded-md text-xs text-cream-400 uppercase tracking-wider;
  }

  .post-pill-date {
    @apply text-navy-300;
  }

  .post-title {
    @apply text-2xl font-bold text-cream-100 tracking-tight leading-tight;
  }

  .post-desc {
    @apply text-base text-cream-400 m-0 leading-relaxed;
  }

  .prose {
    @apply max-w-3xl;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3) {
    @apply font-bold text-cream-100 mt-14 mb-4;
  }

  .prose :global(h1) {
    @apply text-2xl;
  }
  .prose :global(h2) {
    @apply text-xl;
  }
  .prose :global(h3) {
    @apply text-lg;
  }

  .prose :global(p) {
    @apply text-base text-cream-200 leading-7 mb-6;
  }

  .prose :global(ul),
  .prose :global(ol) {
    @apply text-base text-cream-200 pl-6 mb-6 leading-7;
  }

  .prose :global(ul) {
    @apply list-disc;
  }
  .prose :global(ol) {
    @apply list-decimal;
  }

  .prose :global(li) {
    @apply mb-2 pl-1;
  }

  .prose :global(li > ul),
  .prose :global(li > ol) {
    @apply mt-2 mb-0;
  }

  .prose :global(a) {
    @apply text-navy-300 hover:text-navy-400 underline underline-offset-2 transition-colors;
  }

  .prose :global(code):not(pre code) {
    @apply text-navy-300 bg-anthracite-850 px-1.5 py-0.5 text-sm;
  }

  /* expressive-code block spacing and focus ring */
  .prose :global(.expressive-code) {
    @apply mb-8;
  }

  .prose :global(.expressive-code pre code:focus-visible) {
    @apply ring-2 ring-navy-400 ring-offset-2 ring-offset-anthracite-900;
    outline: none;
  }

  .prose :global(blockquote) {
    @apply border-l-2 border-navy-500/50 pl-5 text-cream-400 italic mb-6 py-1;
  }

  .prose :global(hr) {
    @apply border-anthracite-800 my-10;
  }

  .prose :global(img) {
    @apply max-w-full h-auto rounded-md border border-anthracite-800 my-6;
  }

  .scroll-top {
    @apply fixed bottom-8 right-8 w-10 h-10 rounded-md;
    @apply bg-anthracite-800 border border-anthracite-700 text-cream-300;
    @apply hover:bg-anthracite-700 hover:text-cream-100;
    @apply cursor-pointer transition-all duration-200;
    @apply flex items-center justify-center text-sm;
  }
</style>
